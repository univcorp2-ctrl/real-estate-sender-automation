# Local development only. Do not commit real secrets.
PROPERTY_SOURCE_MODE=local
LOCAL_PROPERTIES_PATH=data/sample_properties.csv
LOCAL_RECIPIENTS_PATH=data/sample_recipients.csv
DATABASE_PATH=out/local-state.sqlite3
SENDER_SEND_MODE=dry_run
SENDER_FROM_EMAIL=info@example.com
SENDER_FROM_NAME=Example Realty
SENDER_REPLY_TO=info@example.com
SENDER_GROUP_IDS=
MAX_PROPERTIES_PER_CAMPAIGN=5
RECORD_DRY_RUNS=true

# Production via Cloudflare Worker
# AUTOMATION_WORKER_URL=https://real-estate-sender-automation.<your-subdomain>.workers.dev
# WORKER_SHARED_SECRET=replace-with-random-shared-secret
# GOOGLE_DRIVE_FOLDER_ID=your-folder-id
# GOOGLE_SERVICE_ACCOUNT_JSON={...}
