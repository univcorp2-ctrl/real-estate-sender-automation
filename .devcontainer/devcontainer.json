{
  "name": "real-estate-sender-automation",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-node",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "pip install -r requirements.txt && cd worker && npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
